# Render provides PORT automatically in production. Use a local value only for development.
PORT=5000

# Allowed frontend origins for CORS.
# Keep localhost for development and add your deployed frontend when needed.
FRONTEND_URL=http://localhost:5173,https://writer-z.vercel.app

# Server-side Gemini API key.
# Get it from Google AI Studio: https://aistudio.google.com/app/apikey
# Keep the real value only in Render/backend/.env, not in this example file.
GEMINI_API_KEY=your_gemini_api_key

# Firebase Admin service account JSON string.
# Get it from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Then paste the full JSON on one line in Render.
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"writerz-uk3312"}
