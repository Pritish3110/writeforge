rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasMatchingUserId(userId) {
      return request.resource.data.userId == userId;
    }

    match /users/{userId} {
      allow read, delete: if isOwner(userId);
      allow create, update: if isOwner(userId);

      match /taskRecords/{taskRecordId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /customTasks/{customTaskId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /taskTemplates/{templateId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /characters/{characterId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /characterRelationships/{relationshipId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /plotPoints/{plotPointId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /drafts/{draftId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /worldElements/{worldElementId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }

      match /knowledgeBaseSections/{sectionId} {
        allow read, delete: if isOwner(userId);
        allow create, update: if isOwner(userId) && hasMatchingUserId(userId);
      }
    }
  }
}
